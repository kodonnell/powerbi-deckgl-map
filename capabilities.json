{
    "dataRoles": [
        {
            "displayName": "Geometry ID",
            "name": "geometryId",
            "kind": "Grouping",
            "description": "A unique identifier for each geometry"
        },
        {
            "displayName": "Layer Type",
            "name": "layerType",
            "kind": "Measure",
            "description": "The type of geometry - by default, the string 'scatter', 'line' (A->B), 'arc' (A-> B), 'path' (A->B->C ...) or 'polygon'"
        },
        {
            "displayName": "Point1 Latitude",
            "name": "point1Latitude",
            "kind": "Measure",
            "description": "Scatter: this is the latitude of the point. Lines/arcs: this is the latitude of the starting point"
        },
        {
            "displayName": "Point1 Longitude",
            "name": "point1Longitude",
            "kind": "Measure",
            "description": "Scatter: this is the longitude of the point. Lines/arcs: this is the longitude of the starting point"
        },
        {
            "displayName": "Point2 Latitude",
            "name": "point2Latitude",
            "kind": "Measure",
            "description": "Lines/arcs: this is the latitude of the ending point"
        },
        {
            "displayName": "Point2 Longitude",
            "name": "point2Longitude",
            "kind": "Measure",
            "description": "Lines/arcs: this is the longitude of the ending point"
        },
        {
            "displayName": "Well Known Text",
            "name": "wkt",
            "kind": "Measure",
            "description": "Geometry in WKT format. (If using line/arc you must use Point1/Point2.)"
        },
        {
            "displayName": "Well Known Polyline",
            "name": "wkp",
            "kind": "Measure",
            "description": "Geometry in WKP format. (If using line/arc you must use Point1/Point2.)"
        },
        {
            "displayName": "Scatter radius (m)",
            "name": "scatterRadius",
            "kind": "Measure",
            "description": "The radius of scatter in meters"
        },
        {
            "displayName": "Scatter line width (m)",
            "name": "scatterLineWidth",
            "kind": "Measure",
            "description": "The width of scatter's lines in meters"
        },
        {
            "displayName": "Scatter line color",
            "name": "scatterLineColor",
            "kind": "Measure",
            "description": "The color of the scatter's lines in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Scatter fill (Hex)",
            "name": "scatterFillColor",
            "kind": "Measure",
            "description": "The fill color of the scatter in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "(Line) line width (m)",
            "name": "lineLineWidth",
            "kind": "Measure",
            "description": "The width of line's lines in meters."
        },
        {
            "displayName": "(Line) line color",
            "name": "lineLineColor",
            "kind": "Measure",
            "description": "The color of the line in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Path width (m)",
            "name": "pathWidth",
            "kind": "Measure",
            "description": "The width of path's lines in meters"
        },
        {
            "displayName": "Path color",
            "name": "pathColor",
            "kind": "Measure",
            "description": "The color of the path in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Polygon line width (m)",
            "name": "polygonLineWidth",
            "kind": "Measure",
            "description": "The width of polygon's lines in meters"
        },
        {
            "displayName": "Polygon line color",
            "name": "polygonLineColor",
            "kind": "Measure",
            "description": "The color of the polygon in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Polygon fill (Hex)",
            "name": "polygonFillColor",
            "kind": "Measure",
            "description": "The fill color of the polygon in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Polygon extrude elevation (meters)",
            "name": "polygonExtrudeElevation",
            "kind": "Measure",
            "description": "Height to extrude the polygon, in meters"
        },
        {
            "displayName": "Arc line width (m)",
            "name": "arcLineWidth",
            "kind": "Measure",
            "description": "The width of arc's lines in meters"
        },
        {
            "displayName": "Arc Source color",
            "name": "arcSourceColor",
            "kind": "Measure",
            "description": "The color of the arc's source in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Arc Target color",
            "name": "arcTargetColor",
            "kind": "Measure",
            "description": "The color of the arc's target in hex format - #RGB, #RRGGBB, or #RRGGBBAA"
        },
        {
            "displayName": "Tooltip HTML",
            "name": "tooltipHtml",
            "kind": "Measure",
            "description": "The HTML to display in the tooltip. You can use CSS = )"
        }
    ],
    "supportsHighlight": false,
